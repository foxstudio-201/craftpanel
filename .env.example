# ──────────────────────────────────────────────────────────────
# CraftPanel environment configuration
# Copy this file to `.env` and adjust the values for your setup.
# ──────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Public URL used for CORS / links (no trailing slash)
APP_URL=http://localhost:3000

# Authentication
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=craftpanel_token
BCRYPT_ROUNDS=10

# Default admin account created on first run (seed)
ADMIN_EMAIL=admin@craftpanel.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345

# Legacy file sandbox (kept for compatibility; real files live under VOLUMES_ROOT)
FILES_ROOT=storage/servers

# Live metrics broadcast interval (ms)
METRICS_INTERVAL=2000

# ── Real infrastructure ────────────────────────────────────────────
# Dedicated, isolated workspace root. When set, services/backups/data/sftp live
# under it (e.g. /srv/multihosting). Leave blank to use the in-project ./storage
# tree. NEVER point this inside /var/lib|/etc|/var/www/pterodactyl.
MULTIHOST_ROOT=
# Explicit overrides (optional — default derived from MULTIHOST_ROOT):
VOLUMES_ROOT=
BACKUPS_ROOT=
FILES_ROOT=

# Docker — project-dedicated network + labels (NEVER pterodactyl_nw).
DOCKER_SOCKET=/var/run/docker.sock
MC_IMAGE=itzg/minecraft-server:latest
MC_PROXY_IMAGE=itzg/mc-proxy:latest
DOCKER_NETWORK=multihost_net

# Centralized port allocator — a dedicated pool kept clear of Pterodactyl/Wings.
PORT_RANGE_MIN=26000
PORT_RANGE_MAX=26999
# Extra ports that must never be allocated (comma-separated). The panel already
# auto-detects live listeners + Docker port maps; list known-but-idle ports here.
RESERVED_PORTS=

# Network identity shown on the infrastructure page
PUBLIC_IP=
INTERNAL_IP=
DOMAIN=
# Optional wildcard base domain for auto-generated subdomains (e.g. apps.example.com)
BASE_DOMAIN=

# ── Cloudflare Tunnel integration (ingress for this project) ────────
# The panel READS the existing tunnel and, by default, only PROPOSES merged
# ingress (writes to a workspace file + validates; never edits /etc or restarts
# cloudflared). Set CF_APPLY_MODE=sudo and install bin/cf-apply.sh to enable
# one-click apply (see docs/INSTALL-coexistence.md).
CF_ENABLED=true
CF_CONFIG=/etc/cloudflared/config.yml
CF_TUNNEL_ID=
CF_SERVICE=cloudflared
BASE_DOMAIN=
CF_APPS_SUBDOMAIN=apps
CF_APPLY_MODE=propose
# CF_PROPOSED=/srv/multihosting/docker/cloudflared-desired.yml

# ── Optional internal Caddy — DISABLED by default ───────────────────
# Ports 80/443 are owned by nginx (Pterodactyl Panel) and Wings on this host, so
# Caddy is OFF and defaults to non-privileged ports if ever enabled.
CADDY_ENABLED=false
CADDY_IMAGE=caddy:2
CADDY_CONTAINER=multihost-caddy
CADDY_ADMIN_URL=http://127.0.0.1:2019
CADDY_ADMIN_BIND=127.0.0.1
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
ACME_EMAIL=

# SFTP server (FileZilla / WinSCP). Username format: <panelUser>.<serverId>
SFTP_ENABLED=true
SFTP_HOST=0.0.0.0
SFTP_PORT=2122
SFTP_PUBLIC_HOST=

# Background job queue. Leave blank for the built-in in-process queue, or point
# at a Redis/Valkey instance to use the Redis driver (durable job mirroring).
# e.g. REDIS_URL=redis://127.0.0.1:6379
REDIS_URL=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Optional MySQL connection (Database page). Leave blank to use mock data.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
